{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "declaration": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "noEmitOnError": false,
    "skipLibCheck": true,
    "strict": false,
    "ignoreDeprecations": "6.0",
    "incremental": false,
    "composite": false,
    "rootDir": "../apps/web/src",
    "outDir": "./dist-types",
    "baseUrl": ".",
    "paths": {
      "@/*": ["../apps/web/src/*"],
      "@test-fixtures/*": ["../apps/web/test/fixtures/*"]
    },
    "types": []
  },
  "include": [
    "../apps/web/src/components/design-system/**/*.ts",
    "../apps/web/src/components/design-system/**/*.tsx",
    "../apps/web/src/components/layout/**/*.ts",
    "../apps/web/src/components/layout/**/*.tsx"
  ],
  "exclude": [
    "../apps/web/src/**/*.stories.tsx",
    "../apps/web/src/**/*.test.tsx",
    "../apps/web/src/**/*.test.ts"
  ]
}
