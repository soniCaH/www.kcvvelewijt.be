{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"],
      "env": [
        "DRUPAL_API_URL",
        "REVALIDATION_SECRET",
        "KCVV_API_URL",
        "FOOTBALISTO_API_URL",
        "NEXT_PUBLIC_SANITY_PROJECT_ID",
        "NEXT_PUBLIC_SANITY_DATASET",
        "SANITY_API_READ_TOKEN"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"],
      "inputs": ["src/**", "tests/**", "vitest.config.*"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "type-check": {
      "dependsOn": ["^build"]
    },
    "@kcvv/studio#typegen": {
      "outputs": ["../web/src/lib/sanity/sanity.types.ts", "schema.json"],
      "inputs": [
        "schemaTypes/**",
        "sanity.cli.ts",
        "../web/src/lib/repositories/*.ts",
        "../../packages/sanity-schemas/src/**"
      ]
    },
    "@kcvv/web#build": {
      "dependsOn": ["^build", "@kcvv/studio#typegen"],
      "outputs": [".next/**", "!.next/cache/**"],
      "env": [
        "DRUPAL_API_URL",
        "REVALIDATION_SECRET",
        "KCVV_API_URL",
        "FOOTBALISTO_API_URL",
        "NEXT_PUBLIC_SANITY_PROJECT_ID",
        "NEXT_PUBLIC_SANITY_DATASET",
        "SANITY_API_READ_TOKEN"
      ]
    },
    "@kcvv/studio#deploy": {
      "dependsOn": ["build"],
      "cache": false
    },
    "@kcvv/sanity-schemas#build": {
      "outputs": []
    }
  }
}
