#!/usr/bin/env bash

# Activate Node version from .nvmrc without sourcing full nvm.sh
# This is fast (~0ms) vs sourcing nvm.sh (~200-500ms)
if [ -f ".nvmrc" ] && [ -d "${NVM_DIR:-$HOME/.nvm}/versions/node" ]; then
  NODE_VERSION=$(cat .nvmrc)
  NODE_PATH="${NVM_DIR:-$HOME/.nvm}/versions/node/v${NODE_VERSION}/bin"
  [ -d "$NODE_PATH" ] && export PATH="$NODE_PATH:$PATH"
fi

echo "🔍 Running pre-commit checks..."

# Run lint-staged for staged files
npx lint-staged

# Type check
echo "📝 Type checking..."
pnpm run type-check


echo "✅ Pre-commit checks passed!"
