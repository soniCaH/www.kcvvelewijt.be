#!/usr/bin/env bash

# Load nvm so hooks use the project's Node version (.nvmrc)
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && . "$NVM_DIR/nvm.sh"

echo "🔍 Running pre-commit checks..."

# Run lint-staged for staged files
npx lint-staged

# Type check
echo "📝 Type checking..."
pnpm run type-check


echo "✅ Pre-commit checks passed!"
