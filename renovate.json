{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "enabled": true,
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":dependencyDashboard",
    ":timezone(Europe/Brussels)",
    "group:nextjsMonorepo",
    "security:openssf-scorecard"
  ],
  "enabledManagers": ["npm", "nvm", "github-actions", "dockerfile"],
  "packageRules": [
    {
      "description": "Security/vulnerability fixes with 🔒",
      "matchUpdateTypes": ["patch"],
      "isVulnerabilityAlert": true,
      "commitMessagePrefix": "🔒 ",
      "semanticCommitType": "fix",
      "semanticCommitScope": "deps",
      "commitMessageAction": "{{semanticCommitType}}({{semanticCommitScope}}): update"
    },
    {
      "description": "Pin dependencies with 📌",
      "matchUpdateTypes": ["pin"],
      "commitMessagePrefix": "📌 ",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "commitMessageAction": "{{semanticCommitType}}({{semanticCommitScope}}): pin"
    },
    {
      "description": "Digest/hash updates with 📌",
      "matchUpdateTypes": ["digest"],
      "commitMessagePrefix": "📌 ",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "commitMessageAction": "{{semanticCommitType}}({{semanticCommitScope}}): update"
    },
    {
      "description": "Major updates with 💥",
      "matchUpdateTypes": ["major"],
      "commitMessagePrefix": "💥 ",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "commitMessageAction": "{{semanticCommitType}}({{semanticCommitScope}}): update"
    },
    {
      "description": "Minor updates with ⬆️",
      "matchUpdateTypes": ["minor"],
      "commitMessagePrefix": "⬆️ ",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "commitMessageAction": "{{semanticCommitType}}({{semanticCommitScope}}): update"
    },
    {
      "description": "Patch updates with ⬆️",
      "matchUpdateTypes": ["patch"],
      "commitMessagePrefix": "⬆️ ",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "commitMessageAction": "{{semanticCommitType}}({{semanticCommitScope}}): update"
    },
    {
      "description": "Rollback/downgrade with ⬇️",
      "matchUpdateTypes": ["rollback"],
      "commitMessagePrefix": "⬇️ ",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "commitMessageAction": "{{semanticCommitType}}({{semanticCommitScope}}): rollback"
    },
    {
      "description": "Replacement packages with 🔄",
      "matchUpdateTypes": ["replacement"],
      "commitMessagePrefix": "🔄 ",
      "semanticCommitType": "chore",
      "semanticCommitScope": "deps",
      "commitMessageAction": "{{semanticCommitType}}({{semanticCommitScope}}): replace"
    },
    {
      "description": "Automerge non-major updates",
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "automerge": true
    },
    {
      "description": "Automerge devDependencies",
      "matchDepTypes": ["devDependencies"],
      "automerge": true
    },
    {
      "description": "Batch all remaining non-major devDependencies into one weekly PR to cut CI runs. Placed before the specific groups below so those (eslint, storybook, typescript, playwright, react types) still win for their packages; everything else (wrangler, prettier, workers-types, etc.) collapses here.",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch", "pin", "digest"],
      "groupName": "dev dependencies (non-major)"
    },
    {
      "description": "Batch all remaining non-major production dependencies into one weekly PR. Specific groups below still override this for their packages.",
      "matchDepTypes": ["dependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "production dependencies (non-major)"
    },
    {
      "description": "Group ESLint packages",
      "groupName": "eslint packages",
      "matchPackageNames": ["/^eslint/", "/^@eslint//"]
    },
    {
      "description": "Group all Storybook packages together (monorepo + eslint plugin) — placed after the eslint group so this rule wins for eslint-plugin-storybook",
      "groupName": "storybook",
      "matchPackageNames": [
        "/^@storybook//",
        "storybook",
        "eslint-plugin-storybook"
      ]
    },
    {
      "description": "Group React types together (including overrides)",
      "groupName": "react types",
      "matchPackageNames": ["@types/react", "@types/react-dom"]
    },
    {
      "description": "Group TypeScript packages",
      "groupName": "typescript packages",
      "matchPackageNames": [
        "/^typescript/",
        "/^@types//",
        "!@types/react",
        "!@types/react-dom"
      ]
    },
    {
      "description": "Only allow stable TypeScript versions (no dev/beta/rc)",
      "matchPackageNames": ["typescript"],
      "allowedVersions": "!/-(dev|beta|rc|alpha|next)/",
      "commitMessageTopic": "TypeScript (stable only)"
    },
    {
      "description": "Separate major Next.js updates",
      "matchPackageNames": ["next"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "major-update"]
    },
    {
      "description": "Auto-update .nvmrc minor/patch (Node.js)",
      "matchManagers": ["nvm"],
      "matchUpdateTypes": ["minor", "patch"],
      "automerge": true,
      "labels": ["node-version"]
    },
    {
      "description": "Major Node.js updates need manual review",
      "matchManagers": ["nvm"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["node-version", "major-update"]
    },
    {
      "description": "Sync @types/node with Node.js major version from .nvmrc",
      "matchPackageNames": ["@types/node"],
      "allowedVersions": "24.x",
      "commitMessageTopic": "@types/node (aligned with .nvmrc)"
    },
    {
      "description": "Group Playwright npm packages and Docker image so they update in lockstep",
      "groupName": "playwright",
      "matchPackageNames": [
        "playwright",
        "@playwright/test",
        "mcr.microsoft.com/playwright"
      ]
    }
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"],
    "automerge": false,
    "commitMessagePrefix": "🔒 ",
    "semanticCommitType": "fix",
    "semanticCommitScope": "deps",
    "commitMessageAction": "{{semanticCommitType}}({{semanticCommitScope}}): update"
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 3am on Monday"],
    "commitMessagePrefix": "🔧 ",
    "commitMessageAction": "chore(deps): update",
    "commitMessageTopic": "lock files"
  },
  "labels": ["dependencies"],
  "rangeStrategy": "pin",
  "semanticCommits": "enabled",
  "commitMessagePrefix": "⬆️ ",
  "semanticCommitType": "chore",
  "semanticCommitScope": "deps",
  "commitMessageAction": "{{semanticCommitType}}({{semanticCommitScope}}): update",
  "commitMessageTopic": "{{depName}}",
  "commitMessageExtra": "to {{#if isPinDigest}}{{{newDigestShort}}}{{else}}{{#if isMajor}}{{prettyNewMajor}}{{else}}{{#if isSingleVersion}}{{prettyNewVersion}}{{else}}{{#if newValue}}{{{newValue}}}{{else}}{{{newDigestShort}}}{{/if}}{{/if}}{{/if}}{{/if}}",
  "postUpdateOptions": ["pnpmDedupe"],
  "prCreation": "immediate",
  "prConcurrentLimit": 3,
  "schedule": ["before 6am on monday"],
  "rebaseWhen": "conflicted"
}
