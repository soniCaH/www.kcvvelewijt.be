{
  "name": "kcvv",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.4",
    "@commitlint/config-conventional": "20.4.4",
    "eslint": "9.39.4",
    "husky": "9.1.7",
    "lint-staged": "16.3.1",
    "prettier": "3.8.1",
    "turbo": "2.8.12"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "msgpackr-extract",
      "sharp",
      "unrs-resolver",
      "workerd"
    ]
  },
  "lint-staged": {
    "apps/web/**/*.{js,jsx,ts,tsx}": [
      "eslint --fix --config apps/web/eslint.config.mjs",
      "prettier --write"
    ],
    "apps/web/**/*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "apps/api/**/*.{js,ts}": [
      "prettier --write"
    ],
    "apps/api/**/*.{json,md}": [
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  }
}
