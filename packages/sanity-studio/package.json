    "react": "19.2.7",
    "sanity": "5.30.0"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "6.0.0",
    "@sanity/icons": "3.7.4",
    "@sanity/ui": "3.2.0",
    "@testing-library/react": "16.3.2",
    "@types/react": "19.2.17",
    "@typescript/native-preview": "7.0.0-dev.20260608.1",
    "@vitejs/plugin-react": "6.0.2",
    "eslint": "10.4.1",
    "happy-dom": "20.10.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "sanity": "5.30.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
