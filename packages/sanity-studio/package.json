{
  "name": "@kcvv/sanity-studio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    },
    "./migrations": {
      "import": "./src/migrations/index.ts",
      "types": "./src/migrations/index.ts"
    }
  },
  "scripts": {
    "type-check": "tsgo --noEmit",
