{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["ES2017"],
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "isolatedModules": true
  },
  "include": ["src/**/*.ts"]
}
